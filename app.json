{
  "expo": {
    "name": "HUNT",
    "slug": "hunt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pockitolabs.hunt",
      "infoPlist": {
        "NSCameraUsageDescription": "HUNT needs camera access to record your video intro.",
        "NSPhotoLibraryUsageDescription": "HUNT needs photo library access to add your profile photos.",
        "NSMicrophoneUsageDescription": "HUNT needs microphone access to record voice messages.",
        "NSLocationWhenInUseUsageDescription": "HUNT uses your location to show nearby members.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0C"
      },
      "package": "com.pockitolabs.hunt",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E8364B",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow HUNT to use your location to show nearby members."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "HUNT needs access to your photos to set your profile picture."
        }
      ],
      "expo-asset",
      "@react-native-community/datetimepicker",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.REPLACE_WITH_YOUR_IOS_REVERSED_CLIENT_ID"
        }
      ]
    ],
    "scheme": "hunt",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0fc5b4ae-36fb-48cc-8d67-b30a876b653e"
      }
    },
    "owner": "carloscalderonsv"
  }
}
